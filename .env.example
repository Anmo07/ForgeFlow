# ==============================================================================
# ForgeFlow Environmental Configuration Template (.env.example)
# ==============================================================================
# Copy this file to `.env` in the repo root (or export variables in your shell).
# Never commit real secrets. All placeholder values must be replaced for production.

# ── DATABASE
# Local SQLite: sqlite:///./dev.db
# Docker/Postgres: postgresql+psycopg2://postgres:postgres@postgres:5432/forgeflow
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/forgeflow

# ── REDIS (Celery broker, caching, rate limiting, session revocation, MFA temp tokens)
REDIS_URL=redis://redis:6379/0

# ── MINIO (S3-compatible object storage for invoice PDFs)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=False

# ── JWT / SESSION SECURITY (REQUIRED — app refuses to start without this)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_TO_A_STRONG_RANDOM_VALUE

# Optional token lifetimes (defaults shown)
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CLOUDFLARE TURNSTILE (Production-Grade Bot Protection — 100% Free Service for small/medium sites)
# Get real production keys from Cloudflare Dashboard (https://dash.cloudflare.com/?to=/:account/turnstile)
# For local development testing, leave the default 1x... test keys.
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# ── CLOUDFLARE TUNNEL (Production Zero Trust Ingress — 100% Free Service for small/medium sites)
# Create a free tunnel via Cloudflare Zero Trust (https://one.dash.cloudflare.com/ -> Access -> Tunnels)
# Paste your production tunnel token below to run via Docker Compose without public ports or static IP.
# CLOUDFLARE_TUNNEL_TOKEN=ey...

# ── FRONTEND
# Backend API base URL used by the Next.js client
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── CORS (comma-separated allowlist; required for cookie-based auth)
# WARNING: Do NOT combine allow_origins=["*"] with allow_credentials=True (defeats cookie security)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500,http://localhost:80,http://localhost

# Backend: "smtp" (production/testing), "console" (development), "file" (testing)
EMAIL_BACKEND=smtp

# SMTP configuration (used when EMAIL_BACKEND=smtp)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@forgeflow.local
SMTP_USE_TLS=false

# Email logging directory (used when EMAIL_BACKEND=file)
EMAIL_LOG_DIR=/tmp/forgeflow_emails

# ── FIELD-LEVEL ENCRYPTION (Phase 3: encrypts mfa_secret, api_keys, etc at rest)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# FIELD_ENCRYPTION_KEY=CHANGE_ME_TO_A_FERNET_KEY

# ── UNVERIFIED USER RESTRICTIONS (Phase 3: optional read-only access for unverified users)
# REQUIRE_EMAIL_VERIFICATION=false

# ── TESTING (set by CI/test runners — do not enable in production)
# TESTING=True

# ── FIELD-LEVEL ENCRYPTION KEY VERSIONING (Phase 5)
# JSON map of version tag → Fernet key for key rotation support.
# When rotating keys, add the new key with a new version and keep old keys
# so existing encrypted data can still be decrypted.
# Generate keys with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# FIELD_ENCRYPTION_KEYS_JSON={"v1":"<fernet_key_1>","v2":"<fernet_key_2>"}
# FIELD_ENCRYPTION_ACTIVE_VERSION=v2

# ── AUTH RATE LIMITING (Phase 5)
# Set to "true" to disable rate limiting (useful for CI/test runners).
# When TESTING=True, rate limiting is automatically disabled.
# RATE_LIMIT_DISABLED=false

# ── PERSONA SWITCHER & MOCK MODE (Sprint A Gating)
# Gate mock persona selection out of production build. Never set to true in production.
NEXT_PUBLIC_ENABLE_PERSONA_SWITCHER=false

# Gate mock backend interceptor. Only set to true in local dev with mock databases. Never true in production/staging.
NEXT_PUBLIC_MOCK_MODE=false

# ── ENTERPRISE SSO / OIDC CONFIGURATION (Sprint E)
GOOGLE_OIDC_CLIENT_ID=google-oidc-client-id-placeholder
GOOGLE_OIDC_CLIENT_SECRET=google-oidc-client-secret-placeholder
OIDC_REDIRECT_URI=http://localhost:8000/api/auth/sso/google/callback

# ── OBSERVABILITY STACK (Sprint R2)
# Sentry settings (leave blank to disable in local development)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# Alertmanager configuration
ALERTMANAGER_SMTP_HOST=localhost:587
ALERTMANAGER_SMTP_FROM=noreply@forgeflow.local
ALERTMANAGER_SMTP_TO=admin@forgeflow.local
ALERTMANAGER_WEBHOOK_URL=http://localhost:5000/webhook

# Grafana configuration
GRAFANA_ADMIN_PASSWORD=admin


